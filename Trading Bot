// ================= BACKEND (Node.js + Express) ================= const express = require('express'); const fs = require('fs'); const { v4: uuidv4 } = require('uuid'); const app = express(); app.use(express.json()); // ===== STATE ===== let AUTO_TRADING = false; let SAFE_MODE = false; let EMERGENCY_STOP = false; let ACCOUNT_SIZE = 10000; let equity = ACCOUNT_SIZE; let equityCurve = [ACCOUNT_SIZE]; let wins = 0; let losses = 0; let tradesToday = 0; let openTrades = {}; let tradeQueue = []; // ===== HELPERS ===== function logResult(status, trade) { const result = { status, symbol: trade?.symbol, time: Date.now() }; console.log(JSON.stringify(result)); return status; } function calculateLevels(trade) { return trade.side === 'BUY' ? { stop: trade.entry * 0.995, tp: trade.entry * 1.01 } : { stop: trade.entry * 1.005, tp: trade.entry * 0.99 }; } function getRR(trade) { return trade.side === 'BUY' ? (trade.tp - trade.entry) / (trade.entry - trade.stop) : (trade.entry - trade.tp) / (trade.stop - trade.entry); } function validateTrade(t) { return t.entry && t.stop && t.tp && t.stop !== t.entry && t.tp !== t.entry; } function calculatePositionSize(balance, riskPct, entry, stop) { const riskAmount = balance * (riskPct / 100); const dist = Math.abs(entry - stop); if (dist < 0.0001) return 0; return Math.min(riskAmount / dist, balance * 10); } function registerTrade(trade) { const id = uuidv4(); openTrades[id] = { id, ...trade, openedAt: Date.now() }; return id; } function closeTrade(id) { delete openTrades[id]; } function getDrawdown() { const peak = Math.max(...equityCurve); return ((peak - equity) / peak) * 100; } function updateEquity(pnl) { equity += pnl; equityCurve.push(equity); } async function executeTrade(trade) { console.log('Executing trade:', trade); return { filled: true, filledSize: trade.size, price: trade.entry }; } async function executeTradeSafe(trade) { const result = await executeTrade(trade); if (!result || !result.filled) { closeTrade(trade.id); return false; } return true; } // ===== MAIN ENGINE ===== async function handleTradeSignal(trade) { if (!AUTO_TRADING) return logResult('OFF', trade); const { stop, tp } = calculateLevels(trade); const t = { ...trade, stop, tp }; if (!validateTrade(t)) return logResult('INVALID', trade); const rr = getRR(t); if (rr < 1.5) return logResult('LOW_RR', trade); const size = calculatePositionSize(equity, 1, t.entry, t.stop); if (size <= 0) return logResult('SIZE_ERR', trade); const id = registerTrade({ ...t, size }); const success = await executeTradeSafe({ ...t, id, size }); if (!success) return logResult('EXEC_FAIL', trade); tradesToday++; return logResult('EXECUTED', trade); } // ===== API ===== app.post('/api/toggle', (req, res) => { AUTO_TRADING = req.body.autoTrading; res.json({ ok: true }); }); app.post('/api/emergency-stop', (req, res) => { AUTO_TRADING = false; EMERGENCY_STOP = true; res.json({ ok: true }); }); app.get('/api/stats', (req, res) => { res.json({ equity, winRate: (wins / Math.max(wins + losses, 1)) * 100, drawdown: getDrawdown(), tradesToday, status: AUTO_TRADING ? 'RUNNING' : 'STOPPED', queue: tradeQueue.length, safeMode: SAFE_MODE, openTrades: Object.values(openTrades), equityCurve: equityCurve.map((e, i) => ({ time: i, equity: e })) }); }); app.post('/webhook', async (req, res) => { const result = await handleTradeSignal(req.body); res.json({ result }); }); app.listen(3000, () => console.log('Server running')); // ================= FRONTEND (React Dashboard) ================= // Use the dashboard code already provided in canvas earlier (React component)
